{
  "name": "@globaltech/mediaforge",
  "version": "0.1.0",
  "author": "Qasim Ali",
  "license": "MIT",
  "nodeModulesDir": "none",
  "exports": {
    ".": "./lib/index.ts"
  },
  "tasks": {
    "test": "deno test --allow-env --allow-run --allow-write --allow-read --allow-sys=uid --ignore=deno-tests/battle.test.ts deno-tests/",
    "test:unit": "deno test --allow-env --allow-run --allow-write --allow-read --allow-sys=uid deno-tests/unit/",
    "test:integration": "deno test --allow-env --allow-run --allow-write --allow-read --allow-sys=uid deno-tests/integration/",
    "check": "deno check lib/index.ts",
    "battle": "deno run --allow-env --allow-run --allow-write --allow-read --allow-sys=uid deno-tests/battle.test.ts"
  },
  "test": {
    "include": [
      "deno-tests/"
    ]
  },
  "check": {
    "include": [
      "lib/",
      "deno-tests/"
    ],
    "exclude": [
      "src/",
      "tests/",
      "dist/",
      "node_modules/"
    ]
  },
  "lint": {
    "include": [
      "lib/"
    ],
    "exclude": [
      "deno-tests",
      "tests/",
      "src/",
      "eslint.config.mjs",
      "node_modules/",
      "dist/"
    ]
  },
  "publish": {
    "include": [
      "lib/**/*.ts",
      "README.md",
      "LICENSE",
      "deno.json"
    ],
    "exclude": [
      "src/**",
      "deno-tests",
      "tests/**",
      "dist/**",
      "node_modules/**"
    ]
  }
}